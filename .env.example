# DokuCreator Environment Variables

# === FRONTEND (.env in project root, used by Vite) ===
# Only needed for production when not using vercel.json rewrites
# VITE_API_URL=https://your-backend.onrender.com/api

# === BACKEND (.env in /backend folder) ===
# MongoDB Atlas connection string (free tier: 512MB)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dokucreator?retryWrites=true&w=majority
# Google Gemini API key
GEMINI_API_KEY=AIzaSy...
# JWT secret for token signing (use a strong random string)
JWT_SECRET=your-secret-key-change-this
# Backend port
PORT=5000
# Frontend URL for CORS (update for production)
FRONTEND_URL=http://localhost:3000
